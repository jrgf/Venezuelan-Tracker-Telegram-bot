# ── Server Config ──
PORT=3000

# ── Fzap API ──
FZAP_API_URL=http://fzap:8080
FZAP_API_KEY=your_fzap_api_key

# ── Webhook Configuration ──
# Webhook URL registered inside Fzap (usually pointing to this bot container/IP)
FZAP_WEBHOOK_URL=http://whatsapp_bot:3000/webhook/messages
FZAP_WEBHOOK_SECRET=your_custom_webhook_secret

# ── WhatsApp Bot Instance ──
# The name of the WhatsApp instance in Fzap API used for the bot
FZAP_INSTANCE=bot_instance

# ── Earthquake Finder Database ──
# URL of the official web search portal
SITE_URL=https://localizadosvenezuela.com

# ── Database Storage ──