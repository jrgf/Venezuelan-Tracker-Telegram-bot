# Optional. Polling mode does not listen on a port, but some platforms still provide one.
PORT=3000

# Telegram Bot API token from BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Official web search portal used by the bot.
SITE_URL=https://localizadosvenezuela.com

# ResponseGrid API configuration
RESPONSEGRID_API_URL=https://api.responsegrid.app
RESPONSEGRID_EMERGENCY_ID=11111111-1111-4111-8111-111111111111

